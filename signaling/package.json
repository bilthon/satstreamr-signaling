{
  "name": "satstreamr-signaling",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "test": "jest --testPathPattern='test/.*\\.test\\.ts$' --runInBand"
  },
  "dependencies": {
    "uuid": "^9.0.0",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.ts"
    ],
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "module": "CommonJS"
        }
      }
    },
    "testTimeout": 15000
  }
}
